# ===========================================================
#  Variables de entorno — Soberanía Relacional
# ===========================================================
# 1. Copia este archivo y renómbralo a ".env.local"
# 2. Rellena los valores con los de tu proyecto de Supabase
#    (Supabase > Project Settings > API)
#
# La WEB PÚBLICA funciona aunque no rellenes esto (muestra
# contenido de ejemplo y los formularios no guardan datos).
# El PANEL DE ADMINISTRACIÓN (/admin) sí necesita las 3 claves.
# ===========================================================

# URL pública de tu proyecto Supabase (ej: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (segura para el navegador). Necesaria para
# el inicio de sesión del panel.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave "service_role" (SECRETA, solo servidor — nunca la subas a GitHub).
# La web y el panel leen/escriben en la base de datos con esta clave.
SUPABASE_SERVICE_ROLE_KEY=

# Avisos por correo (opcional) — Resend. Crea una cuenta gratis en
# https://resend.com y pega tu API Key (empieza con re_). Sin esto, los
# formularios y reservas siguen guardándose en el panel, pero no llega aviso.
RESEND_API_KEY=
NOTIFY_EMAIL=soberaniarelacional@gmail.com

# Datos de contacto que se muestran en la web (opcionales)
# Número de WhatsApp en formato internacional, solo dígitos (ej: 5215512345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=5215512345678
NEXT_PUBLIC_CONTACT_EMAIL=hola@soberaniarelacional.com
